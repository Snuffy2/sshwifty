{
  "name": "sshwifty-ui",
  "version": "0.0.0",
  "description": "Sshwifty Web Front-end Project",
  "private": true,
  "main": "",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "browserslist": [
    "Chrome >= 80",
    "Edge >= 80",
    "Firefox >= 78",
    "Safari >= 14"
  ],
  "devDependencies": {
    "@azurity/pure-nerd-font": "^3.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/compiler-sfc": "^3.5.34",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "buffer": "^6.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.1",
    "events": "^3.3.0",
    "fontfaceobserver": "^2.3.0",
    "globals": "^17.6.0",
    "hack-font": "^3.3.0",
    "iconv-lite": "^0.7.2",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.3.0",
    "normalize.css": "^8.0.1",
    "prettier": "^3.8.3",
    "process": "^0.11.10",
    "roboto-fontface": "^0.10.0",
    "sharp": "^0.34.5",
    "string_decoder": "^1.3.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "vue": "^3.5.34",
    "vue-eslint-parser": "^10.4.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "clean": "node -e \"require('node:fs').rmSync('.tmp', { recursive: true, force: true })\"",
    "generate": "npm run clean && cross-env CGO_ENABLED=0 NODE_ENV=production vite build && cross-env CGO_ENABLED=0 NODE_ENV=production go generate ./...",
    "build": "npm run generate && cross-env CGO_ENABLED=0 node scripts/build.mjs",
    "lint": "eslint \"ui/**/*.{js,vue}\"",
    "lint:fix": "eslint --fix \"ui/**/*.{js,vue}\"",
    "testonly": "vitest run && cross-env CGO_ENABLED=1 go test ./... -race -timeout 30s",
    "test": "npm run generate && npm run testonly"
  },
  "author": "",
  "license": "AGPL-3.0-only",
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^9.0.0",
    "postcss": "^8.4.31",
    "consolidate": "^1.0.4",
    "glob": "^13.0.6",
    "sharp": "^0.34.5",
    "minimatch@3": {
      "brace-expansion": "^5.0.5"
    },
    "minimatch@9": {
      "brace-expansion": "^5.0.5"
    },
    "minimatch@10": {
      "brace-expansion": "^5.0.5"
    }
  }
}
