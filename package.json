    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.3.0",
    "normalize.css": "^8.0.1",
    "prettier": "^3.8.3",
    "process": "^0.11.10",
    "roboto-fontface": "^0.10.0",
    "sharp": "^0.34.5",
    "stream-browserify": "^3.0.0",
    "style-loader": "^4.0.0",
    "svgo": "^4.0.1",
    "terser-webpack-plugin": "^5.5.0",
    "vue": "2.7.16",
    "vue-eslint-parser": "^10.4.0",
    "vue-loader": "^15.11.1",
    "vue-template-compiler": "2.7.16",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-favicons": "^1.5.43"
  },
  "scripts": {
    "dev": "CGO_ENABLED=0 NODE_ENV=development webpack watch --mode=development --config=webpack.config.js",
    "clean": "rm -rf .tmp/ || true",
    "generate": "npm run clean && CGO_ENABLED=0 NODE_ENV=production webpack build --mode=production --config=webpack.config.js",
    "build": "npm run generate && SSHWIFTY_VERSION=${SSHWIFTY_VERSION:-$(git describe --always --dirty='*' --tag 2>/dev/null || printf dev)} && CGO_ENABLED=0 go build -ldflags \"-s -w -X github.com/Snuffy2/sshwifty/application.version=${SSHWIFTY_VERSION}\"",
    "lint": "eslint \"ui/**/*.{js,vue}\"",
    "lint:fix": "eslint --fix \"ui/**/*.{js,vue}\"",
    "testonly": "mocha --require @babel/register --recursive --timeout 3s ./ui/**/*_test.js && CGO_ENABLED=1 go test ./... -race -timeout 30s",
    "test": "npm run generate && npm run testonly"
  },
  "author": "",
  "license": "AGPL-3.0-only",
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^8.0.3",
    "postcss": "^8.4.31",
    "minimatch@3": {
      "brace-expansion": "^1.1.14"
    },
    "minimatch@9": {
      "brace-expansion": "^2.0.3"
    },
    "minimatch@10": {
      "brace-expansion": "^5.0.5"
    }
  }
}
